@model IEnumerable<WorldCup2026_Web.Models.Match>

@{
    ViewData["Title"] = "Turnuva Merkezi";
    var topAnecdote = ViewBag.RandomAnecdote as WorldCup2026_Web.Models.Anecdote;

    var aiAnalysis = ViewBag.AiAnalysis as string ?? "Analiz yükleniyor...";
    var aiHomeName = ViewBag.AiHomeName as string ?? "Ev Sahibi";
    var aiAwayName = ViewBag.AiAwayName as string ?? "Deplasman";
    var aiHomeFlag = ViewBag.AiHomeFlag as string;
    var aiAwayFlag = ViewBag.AiAwayFlag as string;

    int homePct = ViewBag.HomePct ?? 50;
    int awayPct = ViewBag.AwayPct ?? 50;

    var groupLetters = new[] { "A", "B", "C", "D", "E", "F", "G", "H", "I", "J", "K", "L" };

    var groupProgress = new Dictionary<string, (int Played, int Total)>();
    foreach (var letter in groupLetters)
    {
        int played = Model?.Count(m => m.Stage != null && m.Stage.Contains(letter) && m.MatchDate < DateTime.Now) ?? 0;
        int total = Model?.Count(m => m.Stage != null && m.Stage.Contains(letter)) ?? 0;
        groupProgress[letter] = (played, total > 0 ? total : 6);
    }

    var todayStadium = Model?.Where(m => m.Stadium != null && !string.IsNullOrEmpty(m.Stadium.ImageUrl))
                             .Select(m => m.Stadium)
                             .FirstOrDefault();
}

<style>
    ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
    }

    ::-webkit-scrollbar-track {
        background: #0b111e;
        border-left: 1px solid rgba(255,255,255,0.03);
    }

    ::-webkit-scrollbar-thumb {
        background: #1e293b;
        border-radius: 20px;
        border: 2px solid #0b111e;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #00c6ff;
            box-shadow: 0 0 8px rgba(0,198,255,0.4);
        }

    html {
        scrollbar-width: thin;
        scrollbar-color: #1e293b #0b111e;
    }

    .dash-root {
        display: flex;
        flex-direction: column;
        gap: 14px; /* 20px -> 14px yapıldı */
        padding-bottom: 20px; /* 40px -> 20px yapıldı */
    }

    /* ══════════════════════════════════════
           BENTO GRID — YENİ ORAN: hero küçük, anekdot büyük
           Grid: [hero 1fr] [ai 1fr] [anekdot 400px]
           ══════════════════════════════════════ */
    .bento-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 400px;
        gap: 14px; /* 16px -> 14px yapıldı */
        align-items: stretch;
    }

    .bento-card {
        background: #0f1624;
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        padding: 14px 20px; /* Dikey padding 22px -> 14px yapıldı */
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: border-color 0.25s;
        position: relative;
        overflow: hidden;
    }

        .bento-card:hover {
            border-color: rgba(0,198,255,0.22);
        }

    /* ── HERO KARTI (biraz küçültüldü) ── */
    .card-hero {
        background: linear-gradient(145deg, #0b111e 0%, #060a12 100%);
        border-color: rgba(0,198,255,0.1);
    }

    .host-countries-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px; /* 14px -> 10px yapıldı */
    }

    .host-avatar-group {
        display: flex;
        align-items: center;
    }

    .host-avatar {
        width: 28px;
        height: 28px;
        object-fit: cover;
        border-radius: 50%;
        border: 2px solid #0b111e;
        margin-left: -7px;
        box-shadow: 0 3px 8px rgba(0,0,0,0.5);
        transition: transform 0.2s;
    }

        .host-avatar:first-child {
            margin-left: 0;
        }

        .host-avatar:hover {
            transform: translateY(-3px) scale(1.1);
            z-index: 10;
        }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(0,198,255,0.06);
        border: 1px solid rgba(0,198,255,0.15);
        color: #00c6ff;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.08em;
        padding: 4px 10px;
        border-radius: 20px;
        text-transform: uppercase;
    }

    /* Başlık küçültüldü: 26px → 21px */
    .hero-title {
        font-size: 21px;
        font-weight: 800;
        color: #ffffff;
        line-height: 1.25;
        margin: 0 0 8px; /* 10px -> 8px yapıldı */
        letter-spacing: -0.02em;
    }

    .hero-desc {
        font-size: 12px; /* 12.5px -> 12px yapıldı */
        color: #8a94a6;
        line-height: 1.5; /* 1.6 -> 1.5 yapıldı */
        margin: 0 0 12px; /* 16px -> 12px yapıldı */
    }

    .hero-progress-container {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        padding: 8px 14px; /* 10px -> 8px yapıldı */
        border-radius: 12px;
        margin-bottom: 12px; /* 16px -> 12px yapıldı */
    }

    .hero-progress-text {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        font-weight: 700;
        color: #6b7a99;
        margin-bottom: 4px; /* 6px -> 4px yapıldı */
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .hero-progress-bar {
        height: 5px;
        background: #162035;
        border-radius: 10px;
        overflow: hidden;
    }

    .hero-progress-fill {
        height: 100%;
        width: @(((double)(ViewBag.FinishedMatchesCount ?? 0) / 104.0 * 100.0).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))% !important;
        background: linear-gradient(90deg, #0072ff, #00c6ff);
        box-shadow: 0 0 8px rgba(0,198,255,0.6);
        border-radius: 10px;
    }

    .hero-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .stat-box {
        background: rgba(0,0,0,0.25);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 12px;
        padding: 10px 8px; /* 13px -> 10px yapıldı */
        text-align: center;
        transition: background 0.2s, border-color 0.2s;
    }

        .stat-box:hover {
            background: rgba(0,198,255,0.02);
            border-color: rgba(0,198,255,0.15);
        }

    /* Stat numaraları: 24px → 20px */
    .stat-num {
        font-size: 20px;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 4px;
        letter-spacing: -0.03em;
    }

    .stat-label {
        font-size: 10px;
        font-weight: 700;
        color: #4f5b73;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    /* ── AI KARTI ── */
    .card-ai {
        border-color: rgba(0,198,255,0.12);
    }

        .card-ai::before {
            content: "";
            position: absolute;
            bottom: -40px;
            left: -40px;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, rgba(0,198,255,0.05) 0%, transparent 70%);
            pointer-events: none;
        }

    .ai-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px; /* 12px -> 8px yapıldı */
    }

    .ai-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ai-icon {
        width: 28px;
        height: 28px;
        background: rgba(0,198,255,0.1);
        border: 1px solid rgba(0,198,255,0.2);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #00c6ff;
        font-size: 13px;
        flex-shrink: 0;
    }

    .ai-title {
        font-size: 12px;
        font-weight: 600;
        color: #ccd6f6;
        margin: 0;
    }

    .live-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(255,24,68,0.12);
        border: 1px solid rgba(255,24,68,0.25);
        color: #ff4d6d;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.07em;
        padding: 3px 8px;
        border-radius: 20px;
        text-transform: uppercase;
    }

    .live-dot {
        width: 5px;
        height: 5px;
        background: #ff4d6d;
        border-radius: 50%;
        animation: pulse-dot 1.4s ease-in-out infinite;
    }

    @@keyframes pulse-dot {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.4;
            transform: scale(0.7);
        }
    }

    .ai-analysis-box {
        background: rgba(0,0,0,0.25);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 12px;
        padding: 8px 12px 8px 24px; /* Padding daraltıldı */
        font-size: 12px; /* 12.5px -> 12px yapıldı */
        color: #a8b2c8;
        line-height: 1.6; /* 1.7 -> 1.6 yapıldı */
        flex: 1;
        margin-bottom: 10px; /* 14px -> 10px yapıldı */
        font-style: italic;
        position: relative;
    }

        .ai-analysis-box::before {
            content: "\201C";
            position: absolute;
            top: 4px;
            left: 10px;
            font-size: 24px;
            color: rgba(0,198,255,0.2);
            font-style: normal;
            line-height: 1;
        }

    .ai-vs-row {
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 12px;
        padding: 8px 12px; /* 9px -> 8px yapıldı */
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px; /* 10px -> 8px yapıldı */
    }

    .vs-team {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 600;
        color: #ccd6f6;
    }

    .vs-flag {
        width: 20px;
        height: 13px;
        object-fit: cover;
        border-radius: 2px;
        border: 1px solid rgba(255,255,255,0.06);
    }

    .pct-pill-home {
        background: rgba(0,198,255,0.12);
        color: #00c6ff;
        border: 1px solid rgba(0,198,255,0.2);
        font-size: 11px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
    }

    .pct-pill-away {
        background: rgba(255,77,109,0.12);
        color: #ff4d6d;
        border: 1px solid rgba(255,77,109,0.2);
        font-size: 11px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
    }

    .vs-label {
        font-size: 10px;
        font-weight: 700;
        color: #3a4255;
        letter-spacing: 0.06em;
    }

    .btn-ai-cta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        width: 100%;
        padding: 8px; /* 10px -> 8px yapıldı */
        background: linear-gradient(135deg, #0072ff, #00c6ff);
        color: #050a14;
        font-size: 12px;
        font-weight: 700;
        border: none;
        border-radius: 10px;
        text-decoration: none;
        letter-spacing: 0.03em;
        transition: opacity 0.2s, transform 0.15s;
    }

        .btn-ai-cta:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            color: #050a14;
        }

    /* ══════════════════════════════════════
            ANEKDOT & ŞAMPİYON — BÜYÜTÜLDÜ
            ══════════════════════════════════════ */
    .card-side {
        display: flex;
        flex-direction: column;
        gap: 12px; /* 14px -> 12px yapıldı */
    }

    /* Anekdot: çok daha büyük, daha fazla içerik */
    .side-anecdote {
        background: linear-gradient(145deg, #0f1624 0%, #0a1020 100%);
        border: 1px solid rgba(246,166,35,0.1);
        border-radius: 20px;
        padding: 16px 20px; /* 24px -> Dikeyde 16px yapıldı */
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: border-color 0.25s, box-shadow 0.25s;
        position: relative;
        overflow: hidden;
    }

        .side-anecdote::before {
            content: "";
            position: absolute;
            top: -30px;
            right: -30px;
            width: 160px;
            height: 160px;
            background: radial-gradient(circle, rgba(246,166,35,0.06) 0%, transparent 70%);
            pointer-events: none;
        }

        .side-anecdote:hover {
            border-color: rgba(246,166,35,0.28);
            box-shadow: 0 8px 32px rgba(246,166,35,0.06);
        }

    .anecdote-label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        font-weight: 700;
        color: #f6a623;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        margin-bottom: 8px; /* 12px -> 8px yapıldı */
    }

    /* Anekdot başlık: 14px → 17px */
    .anecdote-title {
        font-size: 16px; /* 17px -> 16px yapıldı */
        font-weight: 700;
        color: #ffffff;
        line-height: 1.35;
        margin: 0 0 8px;
    }

    /* Daha fazla satır göster: 4 → 7 (Line clamp 5'e düşürülerek alan kazanıldı) */
    .anecdote-text {
        font-size: 12.5px;
        color: #7a8499;
        line-height: 1.6;
        margin: 0 0 12px;
        display: -webkit-box;
        -webkit-line-clamp: 5; /* 7 -> 5 yapıldı dikey boşluk için */
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    .anecdote-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 10px; /* 14px -> 10px yapıldı */
        border-top: 1px solid rgba(255,255,255,0.05);
        margin-top: auto;
    }

    .anecdote-link {
        font-size: 12px;
        font-weight: 700;
        color: #00c6ff;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: gap 0.15s;
    }

        .anecdote-link:hover {
            gap: 7px;
            color: #00c6ff;
        }

    .anecdote-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: rgba(246,166,35,0.08);
        border: 1px solid rgba(246,166,35,0.15);
        color: #f6a623;
        font-size: 10px;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 20px;
    }

    /* Şampiyon kutusu: biraz büyütüldü */
    .side-champion {
        background: linear-gradient(135deg, #0f1624 0%, #0d1828 100%);
        border: 1px solid rgba(246,166,35,0.15);
        border-radius: 18px;
        padding: 12px 20px; /* 18px 22px -> 12px 20px yapıldı */
        display: flex;
        align-items: center;
        gap: 14px;
        transition: border-color 0.25s, box-shadow 0.25s;
    }

        .side-champion:hover {
            border-color: rgba(246,166,35,0.3);
            box-shadow: 0 4px 20px rgba(246,166,35,0.07);
        }

    .champion-icon {
        width: 38px; /* 42px -> 38px */
        height: 38px;
        background: rgba(246,166,35,0.1);
        border: 1px solid rgba(246,166,35,0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #f6a623;
        font-size: 16px;
        flex-shrink: 0;
    }

    .champion-info {
        flex: 1;
    }

    .champion-label {
        font-size: 10px;
        font-weight: 600;
        color: #4a5568;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-bottom: 2px;
    }

    .champion-name {
        font-size: 15px;
        font-weight: 800;
        color: #ffffff;
    }

        .champion-name span {
            color: #f6a623;
        }

    /* küçük yüzde pill */
    .champion-pct {
        background: rgba(246,166,35,0.1);
        border: 1px solid rgba(246,166,35,0.2);
        color: #f6a623;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
    }

    /* ══════════════════════════════════════════════════════
            TURNUVA BİLGİ & STADYUM WRAPPER
            ══════════════════════════════════════════════════════ */
    .groups-and-stadium-wrapper {
        display: grid !important;
        grid-template-columns: 1fr 520px !important;
        gap: 14px !important; /* 20px -> 14px yapıldı */
        align-items: stretch !important;
        width: 100% !important;
    }

    /* TURNUVA BİLGİ KARTI */
    .tourney-info-card {
        background: #0f1624;
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 18px;
        padding: 14px 18px; /* 22px 22px 20px -> 14px 18px yapıldı */
        display: flex;
        flex-direction: column;
        gap: 12px; /* 16px -> 12px yapıldı */
        box-sizing: border-box;
    }

    .tourney-info-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

    .tourney-info-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        font-weight: 700;
        color: #ccd6f6;
        margin: 0;
    }

        .tourney-info-title i {
            color: #00c6ff;
            font-size: 13px;
        }

    /* 4'lü üst stat grid */
    .tourney-stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
    }

    .tstat-box {
        background: rgba(0,0,0,0.2);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 14px;
        padding: 10px 8px; /* 16px 12px -> 10px 8px yapıldı */
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px; /* 8px -> 4px yapıldı */
        text-align: center;
        transition: border-color 0.2s, background 0.2s, transform 0.15s;
        position: relative;
        overflow: hidden;
    }

        .tstat-box:hover {
            border-color: var(--ts-border);
            background: var(--ts-bg);
            transform: translateY(-2px);
        }

    .tstat-icon {
        width: 32px; /* 36px -> 32px */
        height: 32px;
        border-radius: 10px;
        background: var(--ts-bg);
        border: 1px solid var(--ts-border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        color: var(--ts-color);
        flex-shrink: 0;
    }

    .tstat-num {
        font-size: 24px; /* 28px -> 24px */
        font-weight: 900;
        color: var(--ts-color);
        line-height: 1;
        letter-spacing: -0.03em;
    }

    .tstat-label {
        font-size: 9.5px;
        font-weight: 700;
        color: #4f5b73;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        line-height: 1.2;
    }

    /* Alt bilgi satırı */
    .tourney-facts-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        flex: 1;
    }

    .tourney-fact-box {
        background: rgba(0,0,0,0.18);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 12px;
        padding: 10px 14px; /* 14px 16px -> 10px 14px yapıldı */
        display: flex;
        align-items: center;
        gap: 10px;
        transition: border-color 0.2s;
    }

        .tourney-fact-box:hover {
            border-color: rgba(0,198,255,0.15);
        }

    .fact-icon {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        flex-shrink: 0;
    }

    .fact-content {
        flex: 1;
        min-width: 0;
    }

    .fact-label {
        font-size: 9px;
        font-weight: 700;
        color: #4a5568;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 2px;
    }

    .fact-value {
        font-size: 12.5px;
        font-weight: 700;
        color: #ccd6f6;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .fact-sub {
        font-size: 10.5px;
        color: #4a5568;
        margin-top: 1px;
    }

    /* ══════════════════════════════════════
            STADYUM KARTI
            ══════════════════════════════════════ */
    .dashboard-stadium-card {
        width: 100% !important;
        min-height: 220px; /* 260px -> 220px düşürüldü */
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 18px;
        position: relative;
        overflow: hidden;
        flex-shrink: 0 !important;
        box-sizing: border-box !important;
        transition: border-color 0.25s, transform 0.2s, box-shadow 0.25s;
    }

        .dashboard-stadium-card:hover {
            border-color: rgba(0,198,255,0.3);
            transform: translateY(-3px);
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

    .stadium-card-overlay {
        height: 100%;
        min-height: 220px; /* 260px -> 220px düşürüldü */
        padding: 18px 22px; /* 28px -> 18px dikey yapıldı */
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-sizing: border-box !important;
        background: linear-gradient(to bottom, rgba(11,17,30,0.15) 0%, rgba(11,17,30,0.55) 40%, rgba(11,17,30,0.95) 100%);
    }

    .stadium-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(0,198,255,0.15);
        border: 1px solid rgba(0,198,255,0.3);
        color: #00c6ff;
        font-size: 10px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        align-self: flex-start;
    }

    .stadium-card-bottom {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .stadium-card-name {
        font-size: 20px; /* 22px -> 20px */
        font-weight: 800;
        color: #ffffff;
        margin: 0 0 2px 0;
        text-shadow: 0 2px 8px rgba(0,0,0,0.8);
        letter-spacing: -0.02em;
    }

    .stadium-card-city {
        font-size: 12.5px;
        font-weight: 500;
        color: #a8b2c8;
        margin: 0 0 8px; /* 14px -> 8px */
        text-shadow: 0 1px 4px rgba(0,0,0,0.7);
    }

    .stadium-card-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 2px;
    }

    .stadium-meta-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.1);
        color: #a8b2c8;
        font-size: 11px;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 8px;
    }

        .stadium-meta-pill i {
            font-size: 10px;
            color: #00c6ff;
        }

    .stadium-all-btn {
        align-self: flex-start;
        font-size: 11.5px;
        font-weight: 700;
        color: #ffffff;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.14);
        padding: 6px 14px; /* 8px 18px -> 6px 14px */
        border-radius: 10px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: all 0.2s;
        backdrop-filter: blur(4px);
    }

        .stadium-all-btn:hover {
            background: linear-gradient(135deg, #0072ff, #00c6ff);
            color: #050a14;
            border-color: transparent;
        }

    /* ══════════════════════════════════════
            FİKSTÜR
            ══════════════════════════════════════ */
    .fixture-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px; /* 16px -> 12px yapıldı */
    }

    .fixture-section-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 18px;
        font-weight: 700;
        color: #ffffff;
        margin: 0;
    }

        .fixture-section-title i {
            color: #00c6ff;
        }

    .fixture-link {
        font-size: 12px;
        font-weight: 600;
        color: #00c6ff;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: gap 0.15s;
    }

        .fixture-link:hover {
            gap: 7px;
            color: #00c6ff;
        }

    .fixture-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .fix-card {
        background: #0f1624;
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 16px;
        padding: 14px 22px; /* 16px -> 14px dikey yapıldı */
        display: grid;
        grid-template-columns: 220px 1fr auto 1fr 200px;
        align-items: center;
        gap: 16px;
        transition: border-color 0.2s, background 0.2s, transform 0.15s;
    }

        .fix-card:hover {
            border-color: rgba(0,198,255,0.2);
            background: #111927;
            transform: translateX(2px);
        }

    .fix-meta {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .fix-stage {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        color: #6b7a99;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.06em;
        padding: 2px 8px;
        border-radius: 20px;
        text-transform: uppercase;
        align-self: flex-start;
    }

    .fix-date {
        font-size: 12px;
        color: #4a5568;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .fix-date i {
            color: #00c6ff;
            font-size: 11px;
        }

    .fix-team-r {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
    }

    .fix-team-l {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
    }

    .fix-name {
        font-size: 15px;
        font-weight: 700;
        color: #e2e8f0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 160px;
    }

    .fix-flag {
        width: 32px;
        height: 21px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
    }

    .fix-vs {
        font-size: 11px;
        font-weight: 700;
        color: #2d3748;
        letter-spacing: 0.08em;
        text-align: center;
        padding: 6px 12px;
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 8px;
        background: rgba(0,0,0,0.2);
        white-space: nowrap;
    }

    .fix-stadium {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 5px;
        font-size: 12px;
        color: #4a5568;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .fix-stadium i {
            color: #ef4444;
            font-size: 11px;
            flex-shrink: 0;
        }

    /* ══════════════════════════════════════
            RESPONSIVE
            ══════════════════════════════════════ */
    @@media (max-width: 1300px) {
        .bento-grid {
            grid-template-columns: 1fr 1fr;
        }

        .card-side {
            flex-direction: row;
            grid-column: 1 / -1;
        }

        .side-anecdote {
            flex: 2;
        }

        .side-champion {
            flex: 1;
        }

        .groups-and-stadium-wrapper {
            grid-template-columns: 1fr 380px !important;
        }
    }

    @@media (max-width: 900px) {
        .bento-grid {
            grid-template-columns: 1fr;
        }

        .card-side {
            flex-direction: column;
        }

        .groups-and-stadium-wrapper {
            grid-template-columns: 1fr !important;
        }

        .groups-grid {
            grid-template-columns: repeat(4, 1fr);
        }

        .dashboard-stadium-card {
            min-height: 200px !important;
        }

        .fix-card {
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto auto auto;
        }

        .fix-meta {
            grid-column: 1 / -1;
        }

        .fix-vs {
            justify-self: center;
        }

        .fix-stadium {
            grid-column: 1 / -1;
            justify-content: flex-start;
        }
    }

    @@media (max-width: 600px) {
        .groups-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>

<div class="dash-root">

    <div class="bento-grid">

        <div class="bento-card card-hero">
            <div>
                <div class="host-countries-wrapper">
                    <div class="hero-badge">
                        <i class="bi bi-shield-fill-check" style="font-size:9px;"></i>
                        DURUM ODASI
                    </div>
                    <div class="host-avatar-group">
                        <img src="https://flagcdn.com/w40/us.png" class="host-avatar" title="Amerika Birleşik Devletleri">
                        <img src="https://flagcdn.com/w40/mx.png" class="host-avatar" title="Meksika">
                        <img src="https://flagcdn.com/w40/ca.png" class="host-avatar" title="Kanada">
                    </div>
                </div>
                <h1 class="hero-title">Kuzey Amerika 2026<br>Turnuva Takip Merkezi</h1>
                <p class="hero-desc">
                    48 ülkenin şampiyonluk mücadelesi verdiği dev organizasyonu anlık veritabanı akışı, grup puan durumları ve yapay zeka analizleriyle buradan yönetebilirsiniz.
                </p>
            </div>
            <div class="hero-progress-container">
                <div class="hero-progress-text">
                    <span>Turnuva İlerleme Safhası</span>
                    <span class="text-neon">@ViewBag.FinishedMatchesCount / 104 Maç Tamamlandı</span>
                </div>
                <div class="hero-progress-bar">
                    <div class="hero-progress-fill"></div>
                </div>
            </div>
            <div class="hero-stats">
                <div class="stat-box">
                    <div class="stat-num" style="color:#00c6ff;">48</div>
                    <div class="stat-label">Dev Takım</div>
                </div>
                <div class="stat-box">
                    <div class="stat-num" style="color:#f6a623;">12</div>
                    <div class="stat-label">Grup</div>
                </div>
                <div class="stat-box">
                    <div class="stat-num" style="color:#34d399;">104</div>
                    <div class="stat-label">Toplam Maç</div>
                </div>
            </div>
        </div>

        <div class="bento-card card-ai d-flex flex-column">
            <div class="ai-header">
                <div class="ai-header-left">
                    <div class="ai-icon"><i class="bi bi-cpu-fill"></i></div>
                    <span class="ai-title">Llama3 Analiz Motoru</span>
                </div>
                <span class="live-badge">
                    <span class="live-dot"></span>
                    GROQ Canlı
                </span>
            </div>
            <div class="ai-analysis-box">@aiAnalysis</div>
            <div>
                <div class="ai-vs-row">
                    <div class="vs-team">
                        @if (!string.IsNullOrEmpty(aiHomeFlag))
                        {
                            <img src="@aiHomeFlag" class="vs-flag" alt="@aiHomeName">
                        }
                        <span>@aiHomeName</span>
                        <span class="pct-pill-home">@homePct%</span>
                    </div>
                    <span class="vs-label">VS</span>
                    <div class="vs-team">
                        <span class="pct-pill-away">@awayPct%</span>
                        <span>@aiAwayName</span>
                        @if (!string.IsNullOrEmpty(aiAwayFlag))
                        {
                            <img src="@aiAwayFlag" class="vs-flag" alt="@aiAwayName">
                        }
                    </div>
                </div>
                <a asp-controller="Home" asp-action="AiPredictor" class="btn-ai-cta">
                    <i class="bi bi-lightning-charge-fill"></i>
                    Tüm Yapay Zeka Tahminlerini Aç
                </a>
            </div>
        </div>

        <div class="card-side">
            @if (topAnecdote != null)
            {
                <div class="side-anecdote">
                    <div style="display:flex; flex-direction:column; flex:1;">
                        <div class="anecdote-label">
                            <i class="bi bi-star-fill" style="font-size:9px;"></i>
                            Tarihten Bilgi
                        </div>
                        <h3 class="anecdote-title">@topAnecdote.Title</h3>
                        <p class="anecdote-text">@topAnecdote.Content</p>
                    </div>
                    <div class="anecdote-footer">
                        <a asp-controller="Home" asp-action="AnecdoteDetail" asp-route-id="@topAnecdote.Id" class="anecdote-link">
                            Hikayeyi Oku <i class="bi bi-arrow-right"></i>
                        </a>
                        <span class="anecdote-tag">
                            <i class="bi bi-clock-history" style="font-size:9px;"></i>
                            Tarih
                        </span>
                    </div>
                </div>
            }
            <div class="side-champion">
                <div class="champion-icon">
                    <i class="bi bi-trophy-fill"></i>
                </div>
                <div class="champion-info">
                    <div class="champion-label">AI Şampiyonluk Favorisi</div>
                    <div class="champion-name">🇦🇷 <span>Arjantin</span></div>
                </div>
                <span class="champion-pct">#1</span>
            </div>
        </div>

    </div>

    <div class="groups-and-stadium-wrapper">

        <div class="tourney-info-card">
            <div class="tourney-info-header">
                <h3 class="tourney-info-title">
                    <i class="bi bi-bar-chart-fill"></i>
                    Turnuva İstatistikleri
                </h3>
            </div>

            <div class="tourney-stat-grid">
                <div class="tstat-box"
                     style="--ts-color:#00c6ff; --ts-bg:rgba(0,198,255,0.06); --ts-border:rgba(0,198,255,0.2); --ts-glow:rgba(0,198,255,0.08);">
                    <div class="tstat-icon"><i class="bi bi-globe2"></i></div>
                    <div class="tstat-num">6</div>
                    <div class="tstat-label">Kıta</div>
                </div>
                <div class="tstat-box"
                     style="--ts-color:#f6a623; --ts-bg:rgba(246,166,35,0.06); --ts-border:rgba(246,166,35,0.2); --ts-glow:rgba(246,166,35,0.08);">
                    <div class="tstat-icon"><i class="bi bi-flag-fill"></i></div>
                    <div class="tstat-num">8</div>
                    <div class="tstat-label">Turnuva Debutantı</div>
                </div>
                <div class="tstat-box"
                     style="--ts-color:#34d399; --ts-bg:rgba(52,211,153,0.06); --ts-border:rgba(52,211,153,0.2); --ts-glow:rgba(52,211,153,0.08);">
                    <div class="tstat-icon"><i class="bi bi-buildings-fill"></i></div>
                    <div class="tstat-num">16</div>
                    <div class="tstat-label">Stadyum</div>
                </div>
                <div class="tstat-box"
                     style="--ts-color:#a78bfa; --ts-bg:rgba(167,139,250,0.06); --ts-border:rgba(167,139,250,0.2); --ts-glow:rgba(167,139,250,0.08);">
                    <div class="tstat-icon"><i class="bi bi-pin-map-fill"></i></div>
                    <div class="tstat-num">11</div>
                    <div class="tstat-label">Ev Sahibi Şehir</div>
                </div>
            </div>

            <div class="tourney-facts-row">
                <div class="tourney-fact-box">
                    <div class="fact-icon" style="background:rgba(0,198,255,0.08); border:1px solid rgba(0,198,255,0.15); color:#00c6ff;">
                        <i class="bi bi-calendar-range"></i>
                    </div>
                    <div class="fact-content">
                        <div class="fact-label">Turnuva Tarihleri</div>
                        <div class="fact-value">11 Haz — 19 Tem 2026</div>
                        <div class="fact-sub">39 günlük organizasyon</div>
                    </div>
                </div>
                <div class="tourney-fact-box">
                    <div class="fact-icon" style="background:rgba(246,166,35,0.08); border:1px solid rgba(246,166,35,0.15); color:#f6a623;">
                        <i class="bi bi-trophy-fill"></i>
                    </div>
                    <div class="fact-content">
                        <div class="fact-label">Mevcut Şampiyon</div>
                        <div class="fact-value">🇦🇷 Arjantin</div>
                        <div class="fact-sub">Katar 2022 Kazananı</div>
                    </div>
                </div>
                <div class="tourney-fact-box">
                    <div class="fact-icon" style="background:rgba(52,211,153,0.08); border:1px solid rgba(52,211,153,0.15); color:#34d399;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="fact-content">
                        <div class="fact-label">Toplam Kadro</div>
                        <div class="fact-value">1.248 Futbolcu</div>
                        <div class="fact-sub">Takım başına 26 oyuncu</div>
                    </div>
                </div>
                <div class="tourney-fact-box">
                    <div class="fact-icon" style="background:rgba(167,139,250,0.08); border:1px solid rgba(167,139,250,0.15); color:#a78bfa;">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <div class="fact-content">
                        <div class="fact-label">Rekor Genişleme</div>
                        <div class="fact-value">32 → 48 Takım</div>
                        <div class="fact-sub">%50 daha fazla katılımcı</div>
                    </div>
                </div>
            </div>
        </div>

        @if (todayStadium != null)
        {
            <div class="dashboard-stadium-card"
                 style="background: linear-gradient(180deg, rgba(11,17,30,0.15) 0%, #0f1624 100%), url('@todayStadium.ImageUrl') center/cover no-repeat;">
                <div class="stadium-card-overlay">
                    <div class="stadium-badge">
                        <i class="bi bi-geo-alt-fill"></i> Turnuva Stadyumu
                    </div>
                    <div class="stadium-card-bottom">
                        <div>
                            <h4 class="stadium-card-name">@todayStadium.Name</h4>
                            <p class="stadium-card-city">@todayStadium.City, @todayStadium.Country</p>
                        </div>
                        <div class="stadium-card-meta">
                            <span class="stadium-meta-pill">
                                <i class="bi bi-people-fill"></i> FIFA 2026 Ev Sahibi
                            </span>
                            <span class="stadium-meta-pill">
                                <i class="bi bi-calendar-check"></i> Aktif Arena
                            </span>
                        </div>
                        <a asp-controller="Home" asp-action="Stadiums" class="stadium-all-btn">
                            Tüm Statları Gör <i class="bi bi-arrow-right-short"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="dashboard-stadium-card"
                 style="background: linear-gradient(145deg, #0b111e 0%, #060a12 100%);">
                <div class="stadium-card-overlay">
                    <div class="stadium-badge">
                        <i class="bi bi-geo-alt-fill"></i> Stadyum Rehberi
                    </div>
                    <div class="stadium-card-bottom">
                        <div>
                            <h4 class="stadium-card-name">Ev Sahibi Arenalar</h4>
                            <p class="stadium-card-city">ABD, Meksika &amp; Kanada</p>
                        </div>
                        <div class="stadium-card-meta">
                            <span class="stadium-meta-pill">
                                <i class="bi bi-buildings-fill"></i> 16 Stadyum
                            </span>
                            <span class="stadium-meta-pill">
                                <i class="bi bi-globe2"></i> 3 Ülke
                            </span>
                        </div>
                        <a asp-controller="Home" asp-action="Stadiums" class="stadium-all-btn">
                            Tüm Statları Gör <i class="bi bi-arrow-right-short"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div>
        <div class="fixture-section-header">
            <h2 class="fixture-section-title">
                <i class="bi bi-calendar2-event"></i>
                Yaklaşan Turnuva Fikstürü
            </h2>
            <a asp-controller="Home" asp-action="AiPredictor" class="fixture-link">
                Tüm Programı Gör <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div class="fixture-list">
            @foreach (var match in Model.Take(4))
            {
                <div class="fix-card">
                    <div class="fix-meta">
                        <span class="fix-stage">
                            <i class="bi bi-trophy" style="font-size:8px;"></i>
                            @match.Stage?.ToUpper()
                        </span>
                        <div class="fix-date">
                            <i class="bi bi-clock"></i>
                            @match.MatchDate.ToString("dd.MM.yyyy HH:mm dddd")
                        </div>
                    </div>
                    <div class="fix-team-r">
                        <span class="fix-name">@match.HomeTeam?.Name</span>
                        <img src="@match.HomeTeam?.FlagUrl" class="fix-flag" alt="@match.HomeTeam?.Name" onerror="this.style.display='none'">
                    </div>
                    <div class="fix-vs">VS</div>
                    <div class="fix-team-l">
                        <img src="@match.AwayTeam?.FlagUrl" class="fix-flag" alt="@match.AwayTeam?.Name" onerror="this.style.display='none'">
                        <span class="fix-name">@match.AwayTeam?.Name</span>
                    </div>
                    <div class="fix-stadium">
                        <i class="bi bi-geo-alt-fill"></i>
                        <span title="@match.Stadium?.Name">@match.Stadium?.Name</span>
                    </div>
                </div>
            }
        </div>
    </div>

</div>