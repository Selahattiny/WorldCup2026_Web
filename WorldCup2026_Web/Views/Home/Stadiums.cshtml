@model WorldCup2026_Web.Models.Stadium

@{
    ViewData["Title"] = "Stadyumlar & Ev Sahibi Şehirler";
    var allStadiums = (ViewBag.AllStadiums as IEnumerable<WorldCup2026_Web.Models.Stadium>)?.ToList()
                      ?? new List<WorldCup2026_Web.Models.Stadium>();
    var stadiumMatches = (ViewBag.StadiumMatches as IEnumerable<WorldCup2026_Web.Models.Match>)?.ToList()
                      ?? new List<WorldCup2026_Web.Models.Match>();

    int totalCapacity = allStadiums.Sum(s => s.Capacity);
    var citiesCount = allStadiums.Select(s => s.City).Distinct().Count();
}

<style>
    /* ══════════════════════════════════════
         GLOBAL CUSTOM DARK SCROLLBAR DESIGN
       ══════════════════════════════════════ */

    /* 1. Tüm sayfanın kaydırma çubuğu genişliği */
    ::-webkit-scrollbar {
        width: 10px; /* Dikey scroll genişliği */
        height: 10px; /* Yatay scroll yüksekliği */
    }

    /* 2. Kaydırma çubuğunun arkasındaki ray/arka plan (Track) */
    ::-webkit-scrollbar-track {
        background: #0b111e; /* Dashboard arka plan renginizle tam uyumlu koyu ton */
        border-left: 1px solid rgba(255, 255, 255, 0.03);
    }

    /* 3. Tutup aşağı yukarı kaydırdığımız hareketli çubuk (Thumb) */
    ::-webkit-scrollbar-thumb {
        background: #1e293b; /* Kart sınırları tonunda koyu gri */
        border-radius: 20px; /* Yuvarlak, modern köşeler */
        border: 2px solid #0b111e; /* Ray ile çubuk arasında boşluk hissi yaratır */
        transition: background 0.2s;
    }

        /* 4. Çubuğun üzerine fareyle gelindiğindeki hali (Hover) */
        ::-webkit-scrollbar-thumb:hover {
            background: #00c6ff; /* Temanızdaki o şık neon mavi renk! */
            box-shadow: 0 0 8px rgba(0, 198, 255, 0.4);
        }

    /* Standart tarayıcılar (Firefox vb.) için modern scrollbar desteği */
    html {
        scrollbar-width: thin;
        scrollbar-color: #1e293b #0b111e;
    }
    /* ══════════════════════════════════════
           SAYFA BAŞLIK
        ══════════════════════════════════════ */
    .stad-page {
        padding-bottom: 48px;
    }

    .stad-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .stad-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(0, 198, 255, 0.08);
        border: 1px solid rgba(0, 198, 255, 0.2);
        color: #00c6ff;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 20px;
        margin-bottom: 10px;
    }

    .stad-title {
        font-size: 26px;
        font-weight: 700;
        color: #ffffff;
        margin: 0 0 6px;
        line-height: 1.2;
    }

    .stad-sub {
        font-size: 13px;
        color: #4a5568;
        margin: 0;
    }

    .stad-summary {
        display: flex;
        gap: 10px;
        flex-shrink: 0;
    }

    .stad-summary-pill {
        background: #0f1624;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 10px 18px;
        text-align: center;
        min-width: 90px;
    }

    .stad-summary-num {
        font-size: 20px;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 3px;
    }

    .stad-summary-label {
        font-size: 10px;
        font-weight: 600;
        color: #3a4255;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    /* ══════════════════════════════════════
           LAYOUT
        ══════════════════════════════════════ */
    .stad-layout {
        display: grid;
        grid-template-columns: 250px 1.3fr 1fr;
        gap: 16px;
        align-items: start;
    }

    /* ══════════════════════════════════════
           SIDEBAR
        ══════════════════════════════════════ */
    .stad-sidebar {
        background: #0f1624;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        padding: 14px;
        max-height: 760px;
        display: flex;
        flex-direction: column;
    }

    .sidebar-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: #3a4255;
        padding: 4px 10px 10px;
    }

    .sidebar-search-wrap {
        position: relative;
        margin-bottom: 10px;
        flex-shrink: 0;
    }

    .sidebar-search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #3a4255;
        font-size: 12px;
        pointer-events: none;
    }

    .sidebar-search {
        width: 100%;
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 10px;
        padding: 9px 12px 9px 34px;
        font-size: 12.5px;
        color: #ccd6f6;
        outline: none;
        transition: border-color 0.2s;
        font-family: inherit;
    }

        .sidebar-search::placeholder {
            color: #3a4255;
        }

        .sidebar-search:focus {
            border-color: rgba(0, 198, 255, 0.3);
        }

    .stad-list {
        overflow-y: auto;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding-right: 4px;
    }

        .stad-list::-webkit-scrollbar {
            width: 6px;
        }

        .stad-list::-webkit-scrollbar-track {
            background: transparent;
        }

        .stad-list::-webkit-scrollbar-thumb {
            background: rgba(0, 198, 255, 0.15);
            border-radius: 10px;
        }

            .stad-list::-webkit-scrollbar-thumb:hover {
                background: rgba(0, 198, 255, 0.3);
            }

    .stad-btn {
        display: flex;
        flex-direction: column;
        gap: 3px;
        width: 100%;
        padding: 10px 12px;
        background: transparent;
        border: 1px solid transparent;
        color: #6b7a99;
        border-radius: 11px;
        text-decoration: none;
        transition: all 0.15s;
    }

        .stad-btn:hover {
            background: rgba(255, 255, 255, 0.03);
            color: #ccd6f6;
        }

        .stad-btn.active {
            background: rgba(0, 198, 255, 0.08);
            border-color: rgba(0, 198, 255, 0.22);
        }

    .stad-btn-city {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 700;
        color: #e2e8f0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .stad-btn.active .stad-btn-city {
        color: #00c6ff;
    }

    .stad-btn-city i {
        font-size: 11px;
        color: #00c6ff;
        flex-shrink: 0;
    }

    .stad-btn-name {
        font-size: 11px;
        color: #3a4255;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        padding-left: 19px;
    }

    .stad-empty {
        text-align: center;
        color: #2d3748;
        font-size: 12px;
        padding: 20px 0;
    }

    /* ══════════════════════════════════════
           ANA STADYUM KARTI
        ══════════════════════════════════════ */
    .stad-main-card {
        background: #0f1624;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 20px;
        padding: 22px;
        position: relative;
        overflow: hidden;
    }

        .stad-main-card::before {
            content: "";
            position: absolute;
            top: -70px;
            right: -70px;
            width: 220px;
            height: 220px;
            background: radial-gradient(circle, rgba(0, 198, 255, 0.07) 0%, transparent 70%);
            pointer-events: none;
        }

    .stad-main-header {
        position: relative;
        z-index: 1;
        margin-bottom: 16px;
    }

    .stad-main-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.22);
        color: #f87171;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 4px 11px;
        border-radius: 20px;
        margin-bottom: 10px;
    }

    .stad-main-city {
        font-size: 26px;
        font-weight: 800;
        color: #ffffff;
        margin: 0 0 4px;
        line-height: 1.15;
    }

    .stad-main-name {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 14px;
        font-weight: 600;
        color: #00c6ff;
        margin: 0;
    }

    /* Görsel */
    .stad-image-wrap {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 18px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
    }

    .stad-image {
        width: 100%;
        height: 260px;
        object-fit: cover;
        display: block;
    }

    .stad-image-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: linear-gradient(180deg, transparent, rgba(8, 12, 20, 0.85));
        pointer-events: none;
    }

    .stad-capacity-chip {
        position: absolute;
        bottom: 12px;
        left: 14px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: rgba(8, 12, 20, 0.6);
        border: 1px solid rgba(0, 198, 255, 0.25);
        backdrop-filter: blur(6px);
        color: #00c6ff;
        font-size: 13px;
        font-weight: 700;
        padding: 6px 14px;
        border-radius: 20px;
    }

        .stad-capacity-chip i {
            font-size: 13px;
        }

    /* Detay kutusu */
    .stad-detail-box {
        position: relative;
        z-index: 1;
    }

    .stad-detail-header {
        display: flex;
        align-items: center;
        gap: 9px;
        margin-bottom: 12px;
    }

    .stad-detail-icon {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        background: rgba(246, 166, 35, 0.1);
        border: 1px solid rgba(246, 166, 35, 0.22);
        color: #f6a623;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .stad-detail-title {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #4a5568;
        margin: 0;
    }

    .stad-detail-text {
        font-size: 13.5px;
        line-height: 1.85;
        color: #aab4cc;
        text-align: justify;
        white-space: pre-line;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 14px;
        padding: 18px;
        margin: 0;
    }

    /* ══════════════════════════════════════
           SAĞ: FİKSTÜR PANELİ
        ══════════════════════════════════════ */
    .stad-fixture-card {
        background: #0f1624;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 20px;
        padding: 20px;
        display: flex;
        flex-direction: column;
    }

    .fixture-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
        padding-bottom: 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .fixture-card-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #f87171;
    }

    .fixture-card-count {
        font-size: 11px;
        font-weight: 700;
        color: #4a5568;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.07);
        padding: 3px 10px;
        border-radius: 20px;
    }

    .fixture-scroll {
        display: flex;
        flex-direction: column;
        gap: 8px;
        max-height: 660px;
        overflow-y: auto;
        padding-right: 4px;
    }

        .fixture-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .fixture-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .fixture-scroll::-webkit-scrollbar-thumb {
            background: rgba(239, 68, 68, 0.15);
            border-radius: 10px;
        }

            .fixture-scroll::-webkit-scrollbar-thumb:hover {
                background: rgba(239, 68, 68, 0.3);
            }

    /* Mini maç kartı */
    .mini-match {
        background: rgba(0, 0, 0, 0.22);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 13px;
        padding: 12px 14px;
        transition: border-color 0.2s, background 0.2s;
    }

        .mini-match:hover {
            border-color: rgba(0, 198, 255, 0.18);
            background: rgba(0, 0, 0, 0.32);
        }

    .mini-match-date {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 700;
        color: #38bdf8;
        margin-bottom: 7px;
    }

        .mini-match-date i {
            font-size: 10px;
        }

    .mini-match-teams {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        margin-bottom: 8px;
    }

    .mini-match-team {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        font-weight: 700;
        color: #e2e8f0;
        min-width: 0;
    }

        .mini-match-team.right {
            justify-content: flex-end;
            text-align: right;
        }

    .mini-flag {
        width: 22px;
        height: 15px;
        object-fit: cover;
        border-radius: 3px;
        border: 1px solid rgba(255, 255, 255, 0.07);
        flex-shrink: 0;
    }

    .mini-match-name {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .mini-match-vs {
        font-size: 10px;
        font-weight: 800;
        color: #2d3748;
        letter-spacing: 0.05em;
        flex-shrink: 0;
    }

    .mini-match-tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.04em;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #f87171;
        padding: 3px 9px;
        border-radius: 20px;
    }

    /* Boş durum */
    .fixture-empty {
        text-align: center;
        color: #2d3748;
        padding: 60px 0;
        font-size: 13px;
    }

        .fixture-empty i {
            font-size: 32px;
            display: block;
            margin-bottom: 10px;
        }

    /* ══════════════════════════════════════
           RESPONSIVE
        ══════════════════════════════════════ */
    @@media (max-width: 1300px) {
        .stad-layout {
            grid-template-columns: 230px 1fr;
        }

        .stad-fixture-card {
            grid-column: 1 / -1;
        }

        .fixture-scroll {
            max-height: 380px;
        }
    }

    @@media (max-width: 900px) {
        .stad-layout {
            grid-template-columns: 1fr;
        }

        .stad-sidebar {
            max-height: 240px;
            flex-direction: row;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .sidebar-label {
            display: none;
        }

        .sidebar-search-wrap {
            flex: 1;
            min-width: 160px;
            margin-bottom: 0;
        }

        .stad-list {
            flex-direction: row;
            overflow-x: auto;
            overflow-y: visible;
            flex: 1 1 100%;
            padding-bottom: 6px;
        }

        .stad-btn {
            min-width: 160px;
            flex-shrink: 0;
        }

        .stad-summary {
            display: none;
        }
    }

    @@media (max-width: 600px) {
        .stad-image {
            height: 200px;
        }

        .stad-main-city {
            font-size: 21px;
        }

        .mini-match-name {
            font-size: 12px;
        }
    }
</style>

<div class="container-fluid mt-4 stad-page">

    <!-- ══ BAŞLIK ══ -->
    <div class="stad-header">
        <div>
            <div class="stad-eyebrow">
                <i class="bi bi-geo-alt-fill" style="font-size:9px;"></i>
                WC 2026 — Resmi Şehirler
            </div>
            <h1 class="stad-title">Turnuva Ev Sahibi Şehirleri & Stadyumları</h1>
            <p class="stad-sub">48 ülkenin sahne alacağı 16 stadyum, 3 ülke, tek dev organizasyon</p>
        </div>

        <div class="stad-summary">
            <div class="stad-summary-pill">
                <div class="stad-summary-num" style="color:#00c6ff;">@allStadiums.Count</div>
                <div class="stad-summary-label">Stadyum</div>
            </div>
            <div class="stad-summary-pill">
                <div class="stad-summary-num" style="color:#34d399;">@citiesCount</div>
                <div class="stad-summary-label">Şehir</div>
            </div>
            <div class="stad-summary-pill">
                <div class="stad-summary-num" style="color:#f6a623;">@((totalCapacity / 1000))K</div>
                <div class="stad-summary-label">Toplam Kapasite</div>
            </div>
        </div>
    </div>

    <!-- ══ LAYOUT ══ -->
    <div class="stad-layout">

        <!-- Sidebar -->
        <div class="stad-sidebar">
            <div class="sidebar-label">Ev Sahibi Merkezler</div>

            <div class="sidebar-search-wrap">
                <i class="bi bi-search sidebar-search-icon"></i>
                <input type="text"
                       class="sidebar-search"
                       id="stad-search-input"
                       placeholder="Şehir veya stadyum ara..."
                       oninput="filterStadiums(this.value)">
            </div>

            <div class="stad-list" id="stad-list">
                @foreach (var s in allStadiums)
                {
                    <a asp-controller="Home" asp-action="Stadiums" asp-route-id="@s.Id"
                       class="stad-btn @(ViewBag.SelectedStadiumId == s.Id ? "active" : "")"
                       data-name="@($"{s.City} {s.Name}".ToLower())">
                        <span class="stad-btn-city">
                            <i class="bi bi-geo-alt-fill"></i>
                            @s.City
                        </span>
                        <span class="stad-btn-name">@s.Name</span>
                    </a>
                }
                <div class="stad-empty" id="stad-empty" style="display:none;">
                    <i class="bi bi-search" style="font-size:18px; display:block; margin-bottom:6px;"></i>
                    Sonuç bulunamadı.
                </div>
            </div>
        </div>

        @if (Model != null)
        {
            <!-- Ana Stadyum Kartı -->
            <div class="stad-main-card">

                <div class="stad-main-header">
                    <span class="stad-main-tag">
                        <i class="bi bi-patch-check-fill" style="font-size:10px;"></i>
                        Resmi Turnuva Rehberi
                    </span>
                    <h2 class="stad-main-city">@Model.City</h2>
                    <p class="stad-main-name">
                        <i class="bi bi-building"></i> @Model.Name
                    </p>
                </div>

                <div class="stad-image-wrap">
                    <img src="@Model.ImageUrl" class="stad-image" alt="@Model.Name" onerror="this.style.display='none'">
                    <div class="stad-image-overlay"></div>
                    <span class="stad-capacity-chip">
                        <i class="bi bi-people-fill"></i>
                        @Model.Capacity.ToString("N0") Seyirci
                    </span>
                </div>

                <div class="stad-detail-box">
                    <div class="stad-detail-header">
                        <div class="stad-detail-icon">
                            <i class="bi bi-journal-text"></i>
                        </div>
                        <h3 class="stad-detail-title">Stadyum & Şehir Detayları</h3>
                    </div>
                    <p class="stad-detail-text">@Model.Description</p>
                </div>

            </div>

            <!-- Sağ: Fikstür -->
            <div class="stad-fixture-card">
                <div class="fixture-card-header">
                    <span class="fixture-card-title">
                        <i class="bi bi-calendar-check"></i>
                        Stadyum Fikstürü
                    </span>
                    <span class="fixture-card-count">@stadiumMatches.Count Maç</span>
                </div>

                <div class="fixture-scroll">
                    @if (stadiumMatches.Any())
                    {
                        @foreach (var m in stadiumMatches.OrderBy(x => x.MatchDate))
                        {
                            <div class="mini-match">
                                <div class="mini-match-date">
                                    <i class="bi bi-clock"></i>
                                    @m.MatchDate.ToString("dd.MM.yyyy HH:mm")
                                </div>
                                <div class="mini-match-teams">
                                    <div class="mini-match-team">
                                        <img src="@m.HomeTeam?.FlagUrl" class="mini-flag" alt="@m.HomeTeam?.Name" onerror="this.style.display='none'">
                                        <span class="mini-match-name">@m.HomeTeam?.Name</span>
                                    </div>
                                    <span class="mini-match-vs">VS</span>
                                    <div class="mini-match-team right">
                                        <span class="mini-match-name">@m.AwayTeam?.Name</span>
                                        <img src="@m.AwayTeam?.FlagUrl" class="mini-flag" alt="@m.AwayTeam?.Name" onerror="this.style.display='none'">
                                    </div>
                                </div>
                                <span class="mini-match-tag">
                                    <i class="bi bi-trophy-fill" style="font-size:9px;"></i>
                                    Dünya Kupası Maçı
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="fixture-empty">
                            <i class="bi bi-calendar-x"></i>
                            Bu stadyumda henüz planlanmış bir maç bulunmuyor.
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<script>
    function filterStadiums(value) {
        const search = value.trim().toLowerCase();
        const items = document.querySelectorAll('#stad-list .stad-btn');
        const emptyMsg = document.getElementById('stad-empty');
        let visibleCount = 0;

        items.forEach(item => {
            const match = item.dataset.name.includes(search);
            item.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
    }
</script>
