@model IEnumerable<WorldCup2026_Web.Models.Team>
@{
    ViewData["Title"] = "Gruplar";
    var groupedTeams = Model.GroupBy(t => t.GroupName).OrderBy(g => g.Key).ToList();
}

<style>
    /* ══════════════════════════════════════
         GLOBAL CUSTOM DARK SCROLLBAR DESIGN
       ══════════════════════════════════════ */

    /* 1. Tüm sayfanın kaydırma çubuğu genişliği */
    ::-webkit-scrollbar {
        width: 10px; /* Dikey scroll genişliği */
        height: 10px; /* Yatay scroll yüksekliği */
    }

    /* 2. Kaydırma çubuğunun arkasındaki ray/arka plan (Track) */
    ::-webkit-scrollbar-track {
        background: #0b111e; /* Dashboard arka plan renginizle tam uyumlu koyu ton */
        border-left: 1px solid rgba(255, 255, 255, 0.03);
    }

    /* 3. Tutup aşağı yukarı kaydırdığımız hareketli çubuk (Thumb) */
    ::-webkit-scrollbar-thumb {
        background: #1e293b; /* Kart sınırları tonunda koyu gri */
        border-radius: 20px; /* Yuvarlak, modern köşeler */
        border: 2px solid #0b111e; /* Ray ile çubuk arasında boşluk hissi yaratır */
        transition: background 0.2s;
    }

        /* 4. Çubuğun üzerine fareyle gelindiğindeki hali (Hover) */
        ::-webkit-scrollbar-thumb:hover {
            background: #00c6ff; /* Temanızdaki o şık neon mavi renk! */
            box-shadow: 0 0 8px rgba(0, 198, 255, 0.4);
        }

    /* Standart tarayıcılar (Firefox vb.) için modern scrollbar desteği */
    html {
        scrollbar-width: thin;
        scrollbar-color: #1e293b #0b111e;
    }
    /* ══════════════════════════════════════
           SAYFA BAŞLIK
        ══════════════════════════════════════ */
    .groups-page {
        padding-bottom: 48px;
    }

    .groups-header {
        margin-bottom: 28px;
    }

    .groups-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(0, 198, 255, 0.08);
        border: 1px solid rgba(0, 198, 255, 0.2);
        color: #00c6ff;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 20px;
        margin-bottom: 10px;
    }

    .groups-title {
        font-size: 26px;
        font-weight: 700;
        color: #ffffff;
        margin: 0 0 6px;
        line-height: 1.2;
    }

    .groups-sub {
        font-size: 13px;
        color: #4a5568;
        margin: 0;
    }

    /* ══════════════════════════════════════
           GRID
        ══════════════════════════════════════ */
    .groups-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    /* ══════════════════════════════════════
           GRUP KARTI
        ══════════════════════════════════════ */
    .group-card {
        background: #0f1624;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        overflow: hidden;
        transition: border-color 0.25s, transform 0.15s;
    }

        .group-card:hover {
            border-color: rgba(0, 198, 255, 0.2);
            transform: translateY(-2px);
        }

    /* Header */
    .group-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 18px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        position: relative;
        overflow: hidden;
    }

        .group-card-header::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--g-grad);
            opacity: 0.08;
            pointer-events: none;
        }

    .group-card-title {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 14px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        position: relative;
        z-index: 1;
    }

    .group-card-icon {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 800;
        color: #050a14;
        background: var(--g-grad);
        flex-shrink: 0;
    }

    .group-card-count {
        font-size: 10px;
        font-weight: 600;
        color: #3a4255;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 3px 9px;
        border-radius: 20px;
        position: relative;
        z-index: 1;
    }

    /* Body / takım listesi */
    .group-card-body {
        display: flex;
        flex-direction: column;
    }

    .team-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 11px 18px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        transition: background 0.15s;
    }

        .team-row:last-child {
            border-bottom: none;
        }

        .team-row:hover {
            background: rgba(255, 255, 255, 0.02);
        }

    .team-row-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .team-rank {
        width: 18px;
        font-size: 11px;
        font-weight: 700;
        color: #2d3748;
        text-align: center;
        flex-shrink: 0;
    }

    .team-flag {
        width: 30px;
        height: 20px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        flex-shrink: 0;
    }

    .team-name {
        font-size: 13.5px;
        font-weight: 600;
        color: #ccd6f6;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .team-fifa {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: #4a5568;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 3px 8px;
        border-radius: 6px;
        flex-shrink: 0;
        margin-left: 10px;
    }

    /* ══════════════════════════════════════
           GRUP RENK PALETİ (12 grup)
        ══════════════════════════════════════ */
    .group-card[data-group="A"] {
        --g-grad: linear-gradient(135deg, #00c6ff, #0072ff);
    }

    .group-card[data-group="B"] {
        --g-grad: linear-gradient(135deg, #a78bfa, #7c3aed);
    }

    .group-card[data-group="C"] {
        --g-grad: linear-gradient(135deg, #34d399, #059669);
    }

    .group-card[data-group="D"] {
        --g-grad: linear-gradient(135deg, #f6a623, #ea580c);
    }

    .group-card[data-group="E"] {
        --g-grad: linear-gradient(135deg, #f472b6, #db2777);
    }

    .group-card[data-group="F"] {
        --g-grad: linear-gradient(135deg, #fb923c, #c2410c);
    }

    .group-card[data-group="G"] {
        --g-grad: linear-gradient(135deg, #38bdf8, #0284c7);
    }

    .group-card[data-group="H"] {
        --g-grad: linear-gradient(135deg, #4ade80, #15803d);
    }

    .group-card[data-group="I"] {
        --g-grad: linear-gradient(135deg, #e879f9, #a21caf);
    }

    .group-card[data-group="J"] {
        --g-grad: linear-gradient(135deg, #fbbf24, #b45309);
    }

    .group-card[data-group="K"] {
        --g-grad: linear-gradient(135deg, #60a5fa, #1d4ed8);
    }

    .group-card[data-group="L"] {
        --g-grad: linear-gradient(135deg, #f9a8d4, #be185d);
    }

    /* ══════════════════════════════════════
           RESPONSIVE
        ══════════════════════════════════════ */
    @@media (max-width: 1100px) {
        .groups-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 680px) {
        .groups-grid {
            grid-template-columns: 1fr;
        }

        .team-name {
            max-width: 160px;
        }
    }
</style>

<div class="container groups-page mt-5">

    <div class="groups-header">
        <div class="groups-eyebrow">
            <i class="bi bi-grid-3x3-gap-fill" style="font-size:9px;"></i>
            WC 2026 — Grup Aşaması
        </div>
        <h1 class="groups-title">Turnuva Grup Dağılımları</h1>
        <p class="groups-sub">Son güncellemelere göre şekillenmiş resmi 12 grup şablonu</p>
    </div>

    <div class="groups-grid">
        @foreach (var group in groupedTeams)
        {
            <div class="group-card" data-group="@group.Key">

                <div class="group-card-header">
                    <div class="group-card-title">
                        <div class="group-card-icon">@group.Key</div>
                        Grup @group.Key
                    </div>
                    <span class="group-card-count">@group.Count() Takım</span>
                </div>

                <div class="group-card-body">
                    @{
                        int rank = 1;
                    }
                    @foreach (var team in group)
                    {
                        <div class="team-row">
                            <div class="team-row-left">
                                <span class="team-rank">@rank</span>
                                <img src="@team.FlagUrl"
                                     class="team-flag"
                                     alt="@team.Name"
                                     onerror="this.style.display='none'">
                                <span class="team-name">@team.Name</span>
                            </div>
                            <span class="team-fifa">@team.FifaCode</span>
                        </div>
                        rank++;
                    }
                </div>

            </div>
        }
    </div>

</div>
