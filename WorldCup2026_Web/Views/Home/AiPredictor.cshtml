@model IEnumerable<WorldCup2026_Web.Models.AiMatchPredictionViewModel>

@{
    ViewData["Title"] = "AI Kahin Tahmin Merkezi";
}

<style>
    /* ══════════════════════════════════════
         GLOBAL CUSTOM DARK SCROLLBAR DESIGN
       ══════════════════════════════════════ */

    /* 1. Tüm sayfanın kaydırma çubuğu genişliği */
    ::-webkit-scrollbar {
        width: 10px; /* Dikey scroll genişliği */
        height: 10px; /* Yatay scroll yüksekliği */
    }

    /* 2. Kaydırma çubuğunun arkasındaki ray/arka plan (Track) */
    ::-webkit-scrollbar-track {
        background: #0b111e; /* Dashboard arka plan renginizle tam uyumlu koyu ton */
        border-left: 1px solid rgba(255, 255, 255, 0.03);
    }

    /* 3. Tutup aşağı yukarı kaydırdığımız hareketli çubuk (Thumb) */
    ::-webkit-scrollbar-thumb {
        background: #1e293b; /* Kart sınırları tonunda koyu gri */
        border-radius: 20px; /* Yuvarlak, modern köşeler */
        border: 2px solid #0b111e; /* Ray ile çubuk arasında boşluk hissi yaratır */
        transition: background 0.2s;
    }

        /* 4. Çubuğun üzerine fareyle gelindiğindeki hali (Hover) */
        ::-webkit-scrollbar-thumb:hover {
            background: #00c6ff; /* Temanızdaki o şık neon mavi renk! */
            box-shadow: 0 0 8px rgba(0, 198, 255, 0.4);
        }

    /* Standart tarayıcılar (Firefox vb.) için modern scrollbar desteği */
    html {
        scrollbar-width: thin;
        scrollbar-color: #1e293b #0b111e;
    }
    /* ── Genel Sayfa ── */
    .ai-page {
        padding: 0;
    }

    /* ── Başlık ── */
    .ai-header {
        margin-bottom: 24px;
    }

    .ai-header-top {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 6px;
    }

    .ai-header-icon {
        width: 36px;
        height: 36px;
        background: rgba(0, 198, 255, 0.08);
        border: 1px solid rgba(0, 198, 255, 0.2);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #00c6ff;
        font-size: 18px;
        flex-shrink: 0;
    }

    .ai-header-title {
        font-size: 20px;
        font-weight: 600;
        color: #ffffff;
    }

    .ai-header-sub {
        font-size: 13px;
        color: #8892b0;
        padding-left: 46px;
    }

    /* ── Filtre Butonları ── */
    .filter-bar {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .filter-btn {
        font-size: 11px;
        padding: 5px 14px;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.04);
        color: #8892b0;
        cursor: pointer;
        transition: all 0.15s;
        font-family: inherit;
        font-weight: 500;
        letter-spacing: 0.03em;
    }

        .filter-btn:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #ccd6f6;
            border-color: rgba(255, 255, 255, 0.2);
        }

        .filter-btn.active {
            background: rgba(0, 198, 255, 0.1);
            border-color: rgba(0, 198, 255, 0.3);
            color: #00c6ff;
        }

    /* ── Tablo Kart ── */
    .ai-table-wrap {
        background: #0f1624;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        overflow: hidden;
    }

    /* ── Tablo Başlığı (Genişlik buton için 220px olarak esnetildi) ── */
    .ai-table-head {
        display: grid;
        grid-template-columns: 210px 1fr 170px 1fr 220px;
        padding: 10px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

        .ai-table-head span {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.09em;
            color: #4a5568;
            text-transform: uppercase;
        }

        .ai-table-head .tc {
            text-align: center;
        }

        .ai-table-head .tr {
            text-align: right;
        }

    /* ── Maç Satırı (Genişlik buton için 220px olarak esnetildi) ── */
    .ai-match-row {
        display: grid;
        grid-template-columns: 210px 1fr 170px 1fr 220px;
        align-items: center;
        padding: 13px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        transition: background 0.15s;
    }

        .ai-match-row:last-child {
            border-bottom: none;
        }

        .ai-match-row:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .ai-match-row.finished {
            opacity: 0.38;
        }

    /* ── Hücre: Meta (Tarih/Durum) ── */
    .cell-meta {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .meta-badges {
        display: flex;
        gap: 5px;
        flex-wrap: wrap;
    }

    .badge-ai {
        font-size: 9px;
        font-weight: 600;
        padding: 2px 7px;
        border-radius: 20px;
        letter-spacing: 0.04em;
    }

    .badge-played {
        background: rgba(255, 24, 68, 0.12);
        color: #ff6b6b;
        border: 1px solid rgba(255, 24, 68, 0.2);
    }

    .badge-stage {
        background: rgba(255, 255, 255, 0.05);
        color: #8892b0;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .badge-group {
        background: rgba(0, 198, 255, 0.08);
        color: #00c6ff;
        border: 1px solid rgba(0, 198, 255, 0.2);
    }

    .meta-date {
        font-size: 11px;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 4px;
    }

        .meta-date i {
            font-size: 11px;
            color: #00f2fe;
        }

        .meta-date.striked {
            text-decoration: line-through;
            color: #374151;
        }

            .meta-date.striked i {
                color: #374151;
            }

    /* ── Hücre: Ev Sahibi / Deplasman ── */
    .cell-home {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 9px;
    }

    .cell-away {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 9px;
    }

    .team-info-r {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    .team-info-l {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .team-name {
        font-size: 13px;
        font-weight: 600;
        color: #ccd6f6;
        line-height: 1.3;
    }

    .pct-home {
        font-size: 11px;
        font-weight: 600;
        color: #00c6ff;
        line-height: 1.2;
    }

    .pct-away {
        font-size: 11px;
        font-weight: 600;
        color: #ff4d6d;
        line-height: 1.2;
    }

    .team-flag {
        width: 27px;
        height: 18px;
        object-fit: cover;
        border-radius: 3px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        flex-shrink: 0;
    }

    /* ── Hücre: Progress Bar ── */
    .cell-bar {
        padding: 0 10px;
    }

    .bar-track {
        height: 8px;
        background: #0a0f1c;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.04);
        overflow: hidden;
        display: flex;
    }

    .bar-home {
        background: linear-gradient(90deg, #0072ff, #00c6ff);
        height: 100%;
        transition: width 0.5s ease;
    }

    .bar-away {
        background: linear-gradient(90deg, #ff4d6d, #ff9a44);
        height: 100%;
        transition: width 0.5s ease;
    }

    /* ── Hücre: Favori ve Buton Alanı ── */
    .cell-fav {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 8px; /* Rozet ve buton arasındaki boşluk */
    }

    .fav-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(245, 158, 11, 0.08);
        border: 1px solid rgba(245, 158, 11, 0.2);
        color: #f59e0b;
        border-radius: 8px;
        padding: 5px 10px;
        font-size: 11px;
        font-weight: 600;
        max-width: 110px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* AI Detay Link Butonu Stilize Ögesi */
    .btn-ai-detail {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: rgba(0, 242, 254, 0.05);
        border: 1px solid rgba(0, 242, 254, 0.25);
        color: #00f2fe;
        border-radius: 8px;
        padding: 5px 10px;
        font-size: 11px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.15s ease;
    }

    .btn-ai-detail:hover {
        background: rgba(0, 242, 254, 0.15);
        border-color: #00f2fe;
        color: #00f2fe;
        box-shadow: 0 0 10px rgba(0, 242, 254, 0.2);
    }

    /* ── Boş Durum ── */
    .ai-empty {
        padding: 56px 0;
        text-align: center;
        color: #4a5568;
        font-size: 14px;
    }

        .ai-empty i {
            font-size: 32px;
            display: block;
            margin-bottom: 10px;
            color: #2d3748;
        }

    /* ── Responsive ── */
    @@media (max-width: 900px) {
        .ai-table-head,
        .ai-match-row {
            grid-template-columns: 160px 1fr 120px 1fr 200px;
        }
    }

    @@media (max-width: 680px) {
        .ai-table-head {
            display: none;
        }

        .ai-match-row {
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto auto auto;
            gap: 8px;
        }

        .cell-bar {
            grid-column: 1 / -1;
            padding: 0;
        }

        .cell-fav {
            justify-content: flex-start;
        }
    }
</style>

<div class="container mt-5 ai-page">

    <div class="ai-header">
        <div class="ai-header-top">
            <div class="ai-header-icon">
                <i class="bi bi-cpu-fill"></i>
            </div>
            <span class="ai-header-title">AI Kahin — Tüm Turnuva Tahminleri</span>
        </div>
        <p class="ai-header-sub">Yapay zekanın takımların form durumlarına göre ürettiği dinamik kupa simülasyonu</p>
    </div>

    <div class="filter-bar">
        <button class="filter-btn active" onclick="filterRows('all', this)">Tümü</button>
        <button class="filter-btn" onclick="filterRows('upcoming', this)">Yaklaşan</button>
        <button class="filter-btn" onclick="filterRows('played', this)">Oynananlar</button>
    </div>

    <div class="ai-table-wrap shadow-lg">

        <div class="ai-table-head">
            <span>Tarih / Durum (TSİ)</span>
            <span class="tr">Ev Sahibi</span>
            <span class="tc">Güç Dengesi (AI)</span>
            <span>Deplasman</span>
            <span class="tr">Favori / Analiz</span>
        </div>

        <div id="match-rows">
            @if (!Model.Any())
            {
                <div class="ai-empty">
                    <i class="bi bi-emoji-neutral"></i>
                    Gösterilecek tahmin bulunamadı.
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    bool isFinished = item.Match != null && item.Match.MatchDate < DateTime.Now;

                    <div class="ai-match-row @(isFinished ? "finished" : "")"
                         data-status="@(isFinished ? "played" : "upcoming")">

                        <div class="cell-meta">
                            <div class="meta-badges">
                                @if (isFinished)
                                {
                                    <span class="badge-ai badge-played">Oynandı</span>
                                }
                                else
                                {
                                    <span class="badge-ai badge-stage">🏆 @item.Match?.Stage?.ToUpper()</span>
                                }
                                @if (item.Match?.HomeTeam != null)
                                {
                                    <span class="badge-ai badge-group">Grup @item.Match.HomeTeam.GroupName</span>
                                }
                            </div>
                            <div class="meta-date @(isFinished ? "striked" : "")">
                                <i class="bi bi-calendar3"></i>
                                @item.Match?.MatchDate.ToString("dd.MM.yyyy HH:mm dddd")
                            </div>
                        </div>

                        <div class="cell-home">
                            <div class="team-info-r">
                                <span class="team-name">@item.Match?.HomeTeam?.Name</span>
                                <span class="pct-home">%@item.HomeWinPercentage</span>
                            </div>
                            <img src="@item.Match?.HomeTeam?.FlagUrl"
                                 class="team-flag"
                                 alt="@item.Match?.HomeTeam?.Name"
                                 onerror="this.style.display='none'">
                        </div>

                        <div class="cell-bar">
                            <div class="bar-track">
                                <div class="bar-home" style="width: @item.HomeWinPercentage%"></div>
                                <div class="bar-away" style="width: @item.AwayWinPercentage%"></div>
                            </div>
                        </div>

                        <div class="cell-away">
                            <img src="@item.Match?.AwayTeam?.FlagUrl"
                                 class="team-flag"
                                 alt="@item.Match?.AwayTeam?.Name"
                                 onerror="this.style.display='none'">
                            <div class="team-info-l">
                                <span class="team-name">@item.Match?.AwayTeam?.Name</span>
                                <span class="pct-away">%@item.AwayWinPercentage</span>
                            </div>
                        </div>

                        <div class="cell-fav">
                            <span class="fav-badge" title="@item.PredictedWinner">
                                <i class="bi bi-star-fill" style="font-size: 10px;"></i>
                                @item.PredictedWinner
                            </span>
                            
                            <a asp-controller="Home" asp-action="MatchDetail" asp-route-id="@item.Match?.Id" class="btn-ai-detail" title="Yapay Zeka Analizini Gör">
                                <i class="bi bi-cpu-fill"></i> Analiz
                            </a>
                        </div>

                    </div>
                }
            }
        </div>
    </div>
</div>

<script>
    function filterRows(type, btn) {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        document.querySelectorAll('.ai-match-row').forEach(row => {
            if (type === 'all') {
                row.style.display = '';
            } else {
                row.style.display = row.dataset.status === type ? '' : 'none';
            }
        });
    }
</script>